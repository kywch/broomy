{
  "name": "Broomy",
  "version": "1.0.0",
  "description": "Multi-agent session manager for AI coding assistants",
  "author": "Rob Ennals <rob.ennals@gmail.com>",
  "homepage": "https://broomy.org",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "node scripts/dev-preflight.cjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "node scripts/stamp-version.cjs && pnpm build && electron-builder; node scripts/restore-version.cjs",
    "dist:signed": "bash scripts/dist-signed.sh",
    "dist:mac": "node scripts/stamp-version.cjs && pnpm build && electron-builder --mac; node scripts/restore-version.cjs",
    "dist:win": "bash scripts/dist-win.sh",
    "dist:linux": "bash scripts/dist-linux.sh",
    "build:linux-prebuilds": "bash scripts/build-linux-prebuilds.sh",
    "dist:all": "bash scripts/dist-all.sh",
    "dist:dir": "node scripts/stamp-version.cjs && pnpm build && electron-builder --dir; node scripts/restore-version.cjs",
    "start": "electron .",
    "start:dist": "node scripts/start-dist.cjs",
    "test:e2e": "E2E_DEV=true playwright test",
    "test:e2e:headed": "E2E_DEV=true E2E_HEADLESS=false playwright test",
    "test:e2e:built": "playwright test",
    "test:e2e:built:headed": "E2E_HEADLESS=false playwright test",
    "screenshots": "GENERATE_SCREENSHOTS=true playwright test tests/screenshots.spec.ts",
    "test:feature-docs": "node scripts/feature-docs.cjs",
    "test:feature-docs:view": "open tests/features/index.html",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "check:workers": "node scripts/check-workers.cjs",
    "check:all": "node scripts/check-all.cjs",
    "website": "pnpm --filter broomy-website dev",
    "version:bump": "node scripts/bump-version.cjs",
    "release": "bash scripts/release.sh",
    "release:all": "bash scripts/release-all.sh",
    "release:compare": "bash scripts/release-screenshot-compare.sh",
    "stats": "node scripts/download-stats.cjs",
    "postinstall": "node scripts/postinstall.cjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:test": "node scripts/storybook-screenshot-test.mjs",
    "storybook:test:quick": "node scripts/storybook-screenshot-test.mjs --no-build",
    "storybook:update-refs": "node scripts/storybook-update-refs.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.7.3",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "path-browserify": "^1.0.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.22.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.1",
    "@storybook/react": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^28.0.0",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.58.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^5.0.10",
    "vitest": "^4.0.18"
  }
}
